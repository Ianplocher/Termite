# FieldRoutes (PestRoutes) API Credentials
# Get these from your FieldRoutes admin panel → Settings → API
FIELDROUTES_SUBDOMAIN=yourcompany
FIELDROUTES_AUTH_KEY=your-authentication-key
FIELDROUTES_AUTH_TOKEN=your-authentication-token

# Optional: Webhook URL (Zapier, Make, etc.) — receives all leads as JSON POST
# This fires IN ADDITION to FieldRoutes, useful for Google Sheets, email alerts, etc.
WEBHOOK_URL=
